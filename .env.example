DATABASE_HOST=aws.connect.psdb.cloud
DATABASE_USERNAME=your-username
DATABASE_PASSWORD=your-password

# Or use a single connection URL:
# DATABASE_URL=mysql://user:pass@host/db

PORT=3001
CORS_ORIGIN=*

# Data retention (days). Metrics older than this are automatically cleaned up.
RETENTION_DAYS=30

# Rate limit for ingest endpoints (requests per minute per IP)
RATE_LIMIT_RPM=100

# TLS (for docker-compose / Traefik)
ACME_EMAIL=you@example.com
